{
  "name": "@number10/phaserjsx",
  "version": "4.0.0",
  "type": "module",
  "description": "Declarative Phaser 4 + UI renderer core library",
  "author": "Michael Rieck (Michael--) <mr@number10.de>",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "jsx-runtime": [
        "dist/jsx-runtime.d.ts"
      ],
      "jsx-dev-runtime": [
        "dist/jsx-dev-runtime.d.ts"
      ]
    }
  },
  "bin": {
    "generate-icons": "./dist/scripts/generate-icons.js",
    "generate-icon-types": "./dist/scripts/generate-icon-types.js",
    "generate-icon-loaders": "./dist/scripts/generate-icon-loaders.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js",
      "require": "./dist/jsx-dev-runtime.cjs"
    },
    "./components/custom": {
      "types": "./dist/components/custom/index.d.ts",
      "import": "./dist/components/custom/index.js",
      "require": "./dist/components/custom/index.cjs"
    },
    "./scripts/icon-generator-config": {
      "types": "./dist/scripts/icon-generator-config.d.ts",
      "import": "./dist/scripts/icon-generator-config.js"
    },
    "./vite-plugin-icons": {
      "types": "./dist/vite-plugin-icons.d.ts",
      "import": "./dist/vite-plugin-icons.js"
    }
  },
  "files": [
    "dist",
    "jsx-runtime.d.ts",
    "jsx-dev-runtime.d.ts"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build && pnpm build:scripts",
    "build:scripts": "vite build --config scripts.vite.config.ts && pnpm build:scripts:types && chmod +x dist/scripts/*.js",
    "build:scripts:types": "tsc --ignoreConfig src/scripts/icon-generator-config.ts src/vite-plugin-icons.ts --declaration --emitDeclarationOnly --declarationMap false --outDir dist --moduleResolution bundler --module ESNext --target ES2022 --skipLibCheck --types node",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "phaser",
    "phaser4",
    "declarative",
    "typescript",
    "game-engine",
    "jsx",
    "react-like",
    "ui",
    "components",
    "hooks"
  ],
  "license": "GPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Michael--/phaserjsx",
    "directory": "packages/ui"
  },
  "homepage": "https://michael--.github.io/phaserjsx/",
  "bugs": {
    "url": "https://github.com/Michael--/phaserjsx/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "phaser": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "phaser": {
      "optional": false
    }
  },
  "dependencies": {
    "@preact/signals-core": "^1.14.2",
    "fast-deep-equal": "^3.1.3",
    "lodash": "^4.18.1",
    "tsx": "^4.22.3"
  }
}
