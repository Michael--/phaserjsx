{
  "name": "phaserjsx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Declarative Phaser 4 + UI framework with TypeScript",
  "author": "Michael Rieck (Michael--) <mr@number10.de>",
  "license": "GPL-3.0-only",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter \"packages/*\" dev & pnpm --filter @phaserjsx/test-ui dev",
    "dev:app": "pnpm --filter @phaserjsx/test-ui dev",
    "ci": "ci-runner",
    "ci:quick": "ci-runner --target quick",
    "ci:build": "ci-runner --target build",
    "ci:targets": "ci-runner --list-targets --format pretty",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "pnpm changeset:version && pnpm -r install --no-frozen-lockfile && pnpm -r build && pnpm changeset:publish",
    "prepare": "husky",
    "doctor": "node -v && pnpm -v && pnpm exec tsc -v",
    "generate-stats": "ts-node scripts/generate-stats.ts",
    "generate-icons": "tsx packages/ui/src/scripts/generate-icon-types.ts -p bootstrap-icons -o apps/test-ui/src/components/icon-types.generated.ts",
    "generate-icon-loaders": "tsx packages/ui/src/scripts/generate-icon-loaders.ts -s apps/test-ui/src -o apps/test-ui/src/components/icon-loaders.generated.ts -p bootstrap-icons",
    "spell": "cspell \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css,html}\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@number10/ci-runner-cli": "^0.2.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "cspell": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
