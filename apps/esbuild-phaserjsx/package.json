{
  "name": "esbuild-phaserjsx",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/index.tsx --bundle --sourcemap --format=esm --outfile=dist/bundle.js --servedir=. --watch",
    "build": "esbuild src/index.tsx --bundle --format=esm --minify --outfile=dist/bundle.js",
    "typecheck": "tsc --noEmit",
    "spell": "cspell \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css,html}\""
  },
  "dependencies": {
    "@number10/phaserjsx": "workspace:*",
    "phaser": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
